# Twitter/X Auth Token (从浏览器 Cookie 获取)
# 登录 https://x.com 后，在开发者工具 Application -> Cookies 中找到 auth_token
AUTH_TOKEN=your_auth_token_here

# 用于只读操作的 Token (可与上面相同)
GET_ID_X_TOKEN=your_auth_token_here

# 服务端口 (可选，默认 3000)
PORT=3000

# 搜索频率限制（可选，默认每IP每5分钟30次）
SEARCH_RATE_WINDOW_MS=300000
SEARCH_RATE_MAX=30
